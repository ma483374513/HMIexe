<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HMIexe.App.ViewModels"
        xmlns:views="using:HMIexe.App.Views"
        x:Class="HMIexe.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1600" Height="900"
        WindowStartupLocation="CenterScreen">

 <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="New Project" Command="{Binding NewProjectCommand}"/>
                <MenuItem Header="Open Project" Command="{Binding OpenProjectCommand}"/>
                <Separator/>
                <MenuItem Header="Save" Command="{Binding SaveProjectCommand}"/>
                <MenuItem Header="Save As..." Command="{Binding SaveProjectAsCommand}"/>
                <Separator/>
                <MenuItem Header="Exit" Command="{Binding ExitApplicationCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="{Binding DesignerViewModel.UndoRedo.UndoDescription, FallbackValue='Undo'}"
                          Command="{Binding UndoCommand}"
                          IsEnabled="{Binding DesignerViewModel.UndoRedo.CanUndo, FallbackValue=False}"/>
                <MenuItem Header="{Binding DesignerViewModel.UndoRedo.RedoDescription, FallbackValue='Redo'}"
                          Command="{Binding RedoCommand}"
                          IsEnabled="{Binding DesignerViewModel.UndoRedo.CanRedo, FallbackValue=False}"/>
                <Separator/>
                <MenuItem Header="Delete Selected Control"
                          Command="{Binding DesignerViewModel.DeleteSelectedControlsCommand}"/>
                <MenuItem Header="Copy"
                          Command="{Binding DesignerViewModel.CopySelectedControlsCommand}"/>
                <MenuItem Header="Paste"
                          Command="{Binding DesignerViewModel.PasteControlsCommand}"/>
                <Separator/>
                <MenuItem Header="Align">
                    <MenuItem Header="Align Left" Command="{Binding DesignerViewModel.AlignLeftCommand}"/>
                    <MenuItem Header="Align Right" Command="{Binding DesignerViewModel.AlignRightCommand}"/>
                    <MenuItem Header="Align Top" Command="{Binding DesignerViewModel.AlignTopCommand}"/>
                    <MenuItem Header="Align Bottom" Command="{Binding DesignerViewModel.AlignBottomCommand}"/>
                    <MenuItem Header="Center Horizontally" Command="{Binding DesignerViewModel.AlignCenterVerticalCommand}"/>
                    <MenuItem Header="Center Vertically" Command="{Binding DesignerViewModel.AlignCenterHorizontalCommand}"/>
                    <Separator/>
                    <MenuItem Header="Distribute Horizontally" Command="{Binding DesignerViewModel.DistributeHorizontallyCommand}"/>
                    <MenuItem Header="Distribute Vertically" Command="{Binding DesignerViewModel.DistributeVerticallyCommand}"/>
                </MenuItem>
                <MenuItem Header="Layer Order">
                    <MenuItem Header="Bring to Front" Command="{Binding DesignerViewModel.BringToFrontCommand}"/>
                    <MenuItem Header="Bring Forward" Command="{Binding DesignerViewModel.BringForwardCommand}"/>
                    <MenuItem Header="Send Backward" Command="{Binding DesignerViewModel.SendBackwardCommand}"/>
                    <MenuItem Header="Send to Back" Command="{Binding DesignerViewModel.SendToBackCommand}"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Return to Designer" Command="{Binding ShowDesignerCommand}"/>
                <MenuItem Header="Run Preview" Command="{Binding ShowRuntimePreviewCommand}"/>
                <Separator/>
                <MenuItem Header="Toggle Grid" Command="{Binding ToggleGridCommand}"/>
                <MenuItem Header="Toggle Theme (Dark/Light)" Command="{Binding ToggleThemeCommand}"/>
            </MenuItem>
            <MenuItem Header="_Project">
                <MenuItem Header="Variable Manager" Command="{Binding ShowVariableManagerCommand}"/>
                <MenuItem Header="Resource Manager" Command="{Binding ShowResourceManagerCommand}"/>
                <MenuItem Header="Script Editor" Command="{Binding ShowScriptEditorCommand}"/>
                <MenuItem Header="Communication Configuration" Command="{Binding ShowCommunicationManagerCommand}"/>
                <MenuItem Header="Alarm Manager" Command="{Binding ShowAlarmManagerCommand}"/>
                <Separator/>
                <MenuItem Header="Publish Project…" Command="{Binding ShowPublishCommand}"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="Settings"/>
                <MenuItem Header="Plugin Manager"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="4,2">
            <Button Content="New" Command="{Binding NewProjectCommand}" ToolTip.Tip="New Project"/>
            <Button Content="Open" Command="{Binding OpenProjectCommand}" ToolTip.Tip="Open Project"/>
            <Button Content="Save" Command="{Binding SaveProjectCommand}" ToolTip.Tip="Save Project"/>
            <Separator Width="1" Background="#444" Margin="2,4"/>
            <Button Content="↩ Undo" Command="{Binding UndoCommand}"
                    IsEnabled="{Binding DesignerViewModel.UndoRedo.CanUndo, FallbackValue=False}"
                    ToolTip.Tip="{Binding DesignerViewModel.UndoRedo.UndoDescription, FallbackValue='Undo'}"/>
            <Button Content="↪ Redo" Command="{Binding RedoCommand}"
                    IsEnabled="{Binding DesignerViewModel.UndoRedo.CanRedo, FallbackValue=False}"
                    ToolTip.Tip="{Binding DesignerViewModel.UndoRedo.RedoDescription, FallbackValue='Redo'}"/>
            <Separator Width="1" Background="#444" Margin="2,4"/>
            <Button Content="Design" Command="{Binding ShowDesignerCommand}" ToolTip.Tip="Return to Designer"/>
            <Button Content="▶ Preview" Command="{Binding ShowRuntimePreviewCommand}" ToolTip.Tip="Run Preview"/>
            <Button Content="Variables" Command="{Binding ShowVariableManagerCommand}" ToolTip.Tip="Variable Manager"/>
            <Button Content="Script" Command="{Binding ShowScriptEditorCommand}" ToolTip.Tip="Script Editor"/>
            <Button Content="Alarms" Command="{Binding ShowAlarmManagerCommand}" ToolTip.Tip="Alarm Manager"/>
            <Button Content="Communication" Command="{Binding ShowCommunicationManagerCommand}" ToolTip.Tip="Communication Configuration"/>
            <Button Content="Resources" Command="{Binding ShowResourceManagerCommand}" ToolTip.Tip="Resource Manager"/>
            <Separator Width="1" Background="#444" Margin="2,4"/>
            <Button Content="📦 Publish" Command="{Binding ShowPublishCommand}" ToolTip.Tip="Project Publishing (Cross-platform Packaging)"/>
        </StackPanel>

        <!-- Status Bar -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8"
                    Background="#1E1E1E" Margin="4,2">
            <TextBlock Text="{Binding StatusText}" Foreground="#AAAAAA" VerticalAlignment="Center"/>
            <TextBlock Text="|" Foreground="#444" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding DesignerViewModel.CurrentPage.Width, StringFormat='{}{0}', FallbackValue='1920'}"
                       Foreground="#AAAAAA" VerticalAlignment="Center"/>
            <TextBlock Text="x" Foreground="#AAAAAA" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding DesignerViewModel.CurrentPage.Height, StringFormat='{}{0}', FallbackValue='1080'}"
                       Foreground="#AAAAAA" VerticalAlignment="Center"/>
            <TextBlock Text="|" Foreground="#444" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding DesignerViewModel.ZoomLevel, StringFormat='Zoom: {0:P0}', FallbackValue='Zoom: 100%'}"
                       Foreground="#AAAAAA" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Main Content: switches between Designer and manager panels -->
        <ContentControl Content="{Binding CurrentContent}">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:DesignerViewModel">
                    <views:DesignerView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="vm:VariableManagerViewModel">
                    <views:VariableManagerView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="vm:ScriptEditorViewModel">
                    <views:ScriptEditorView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="vm:AlarmManagerViewModel">
                    <views:AlarmManagerView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="vm:CommunicationManagerViewModel">
                    <views:CommunicationManagerView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="vm:ResourceManagerViewModel">
                    <views:ResourceManagerView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="vm:RuntimeViewModel">
                    <views:RuntimeView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="vm:PublishViewModel">
                    <views:PublishView DataContext="{Binding}"/>
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>
    </DockPanel>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HMIexe.App.ViewModels"
        xmlns:views="using:HMIexe.App.Views"
        x:Class="HMIexe.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1600" Height="900"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="文件(_F)">
                <MenuItem Header="新建工程" Command="{Binding NewProjectCommand}"/>
                <MenuItem Header="打开工程" Command="{Binding OpenProjectCommand}"/>
                <Separator/>
                <MenuItem Header="保存" Command="{Binding SaveProjectCommand}"/>
                <MenuItem Header="另存为" Command="{Binding SaveProjectAsCommand}"/>
                <Separator/>
                <MenuItem Header="退出" Command="{Binding ExitApplicationCommand}"/>
            </MenuItem>
            <MenuItem Header="编辑(_E)">
                <MenuItem Header="{Binding DesignerViewModel.UndoRedo.UndoDescription, FallbackValue='撤销'}"
                          Command="{Binding UndoCommand}"
                          IsEnabled="{Binding DesignerViewModel.UndoRedo.CanUndo, FallbackValue=False}"/>
                <MenuItem Header="{Binding DesignerViewModel.UndoRedo.RedoDescription, FallbackValue='重做'}"
                          Command="{Binding RedoCommand}"
                          IsEnabled="{Binding DesignerViewModel.UndoRedo.CanRedo, FallbackValue=False}"/>
                <Separator/>
                <MenuItem Header="删除选中控件"
                          Command="{Binding DesignerViewModel.DeleteSelectedControlsCommand}"/>
                <MenuItem Header="复制"
                          Command="{Binding DesignerViewModel.CopySelectedControlsCommand}"/>
                <MenuItem Header="粘贴"
                          Command="{Binding DesignerViewModel.PasteControlsCommand}"/>
                <Separator/>
                <MenuItem Header="对齐">
                    <MenuItem Header="左对齐" Command="{Binding DesignerViewModel.AlignLeftCommand}"/>
                    <MenuItem Header="右对齐" Command="{Binding DesignerViewModel.AlignRightCommand}"/>
                    <MenuItem Header="顶对齐" Command="{Binding DesignerViewModel.AlignTopCommand}"/>
                    <MenuItem Header="底对齐" Command="{Binding DesignerViewModel.AlignBottomCommand}"/>
                    <MenuItem Header="水平居中" Command="{Binding DesignerViewModel.AlignCenterVerticalCommand}"/>
                    <MenuItem Header="垂直居中" Command="{Binding DesignerViewModel.AlignCenterHorizontalCommand}"/>
                    <Separator/>
                    <MenuItem Header="水平均匀分布" Command="{Binding DesignerViewModel.DistributeHorizontallyCommand}"/>
                    <MenuItem Header="垂直均匀分布" Command="{Binding DesignerViewModel.DistributeVerticallyCommand}"/>
                </MenuItem>
                <MenuItem Header="层次顺序">
                    <MenuItem Header="置于顶层" Command="{Binding DesignerViewModel.BringToFrontCommand}"/>
                    <MenuItem Header="向上一层" Command="{Binding DesignerViewModel.BringForwardCommand}"/>
                    <MenuItem Header="向下一层" Command="{Binding DesignerViewModel.SendBackwardCommand}"/>
                    <MenuItem Header="置于底层" Command="{Binding DesignerViewModel.SendToBackCommand}"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="视图(_V)">
                <MenuItem Header="返回设计器" Command="{Binding ShowDesignerCommand}"/>
                <MenuItem Header="运行预览" Command="{Binding ShowRuntimePreviewCommand}"/>
                <Separator/>
                <MenuItem Header="切换网格" Command="{Binding ToggleGridCommand}"/>
                <MenuItem Header="切换主题(深色/浅色)" Command="{Binding ToggleThemeCommand}"/>
            </MenuItem>
            <MenuItem Header="工程(_P)">
                <MenuItem Header="变量管理" Command="{Binding ShowVariableManagerCommand}"/>
                <MenuItem Header="资源管理" Command="{Binding ShowResourceManagerCommand}"/>
                <MenuItem Header="脚本管理" Command="{Binding ShowScriptEditorCommand}"/>
                <MenuItem Header="通信配置" Command="{Binding ShowCommunicationManagerCommand}"/>
                <MenuItem Header="报警管理" Command="{Binding ShowAlarmManagerCommand}"/>
            </MenuItem>
            <MenuItem Header="工具(_T)">
                <MenuItem Header="设置"/>
                <MenuItem Header="插件管理"/>
            </MenuItem>
            <MenuItem Header="帮助(_H)">
                <MenuItem Header="关于" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="4,2">
            <Button Content="新建" Command="{Binding NewProjectCommand}" ToolTip.Tip="新建工程"/>
            <Button Content="打开" Command="{Binding OpenProjectCommand}" ToolTip.Tip="打开工程"/>
            <Button Content="保存" Command="{Binding SaveProjectCommand}" ToolTip.Tip="保存工程"/>
            <Separator Width="1" Background="#444" Margin="2,4"/>
            <Button Content="↩ 撤销" Command="{Binding UndoCommand}"
                    IsEnabled="{Binding DesignerViewModel.UndoRedo.CanUndo, FallbackValue=False}"
                    ToolTip.Tip="{Binding DesignerViewModel.UndoRedo.UndoDescription, FallbackValue='撤销'}"/>
            <Button Content="↪ 重做" Command="{Binding RedoCommand}"
                    IsEnabled="{Binding DesignerViewModel.UndoRedo.CanRedo, FallbackValue=False}"
                    ToolTip.Tip="{Binding DesignerViewModel.UndoRedo.RedoDescription, FallbackValue='重做'}"/>
            <Separator Width="1" Background="#444" Margin="2,4"/>
            <Button Content="设计" Command="{Binding ShowDesignerCommand}" ToolTip.Tip="返回设计器"/>
            <Button Content="▶ 预览" Command="{Binding ShowRuntimePreviewCommand}" ToolTip.Tip="运行预览"/>
            <Button Content="变量" Command="{Binding ShowVariableManagerCommand}" ToolTip.Tip="变量管理"/>
            <Button Content="脚本" Command="{Binding ShowScriptEditorCommand}" ToolTip.Tip="脚本编辑器"/>
            <Button Content="报警" Command="{Binding ShowAlarmManagerCommand}" ToolTip.Tip="报警管理"/>
            <Button Content="通信" Command="{Binding ShowCommunicationManagerCommand}" ToolTip.Tip="通信配置"/>
            <Button Content="资源" Command="{Binding ShowResourceManagerCommand}" ToolTip.Tip="资源管理"/>
        </StackPanel>

        <!-- Status Bar -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8"
                    Background="#1E1E1E" Margin="4,2">
            <TextBlock Text="{Binding StatusText}" Foreground="#AAAAAA" VerticalAlignment="Center"/>
            <TextBlock Text="|" Foreground="#444" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding DesignerViewModel.CurrentPage.Width, StringFormat='{}{0}', FallbackValue='1920'}"
                       Foreground="#AAAAAA" VerticalAlignment="Center"/>
            <TextBlock Text="x" Foreground="#AAAAAA" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding DesignerViewModel.CurrentPage.Height, StringFormat='{}{0}', FallbackValue='1080'}"
                       Foreground="#AAAAAA" VerticalAlignment="Center"/>
            <TextBlock Text="|" Foreground="#444" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding DesignerViewModel.ZoomLevel, StringFormat='缩放: {0:P0}', FallbackValue='缩放: 100%'}"
                       Foreground="#AAAAAA" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Main Content: switches between Designer and manager panels -->
        <ContentControl Content="{Binding CurrentContent}">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:DesignerViewModel">
                    <views:DesignerView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="vm:VariableManagerViewModel">
                    <views:VariableManagerView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="vm:ScriptEditorViewModel">
                    <views:ScriptEditorView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="vm:AlarmManagerViewModel">
                    <views:AlarmManagerView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="vm:CommunicationManagerViewModel">
                    <views:CommunicationManagerView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="vm:ResourceManagerViewModel">
                    <views:ResourceManagerView DataContext="{Binding}"/>
                </DataTemplate>
                <DataTemplate DataType="vm:RuntimeViewModel">
                    <views:RuntimeView DataContext="{Binding}"/>
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>
    </DockPanel>
</Window>

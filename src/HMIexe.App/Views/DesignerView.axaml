<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HMIexe.App.ViewModels"
             xmlns:core="using:HMIexe.Core.Models.Controls"
             xmlns:canvas="using:HMIexe.Core.Models.Canvas"
             x:Class="HMIexe.App.Views.DesignerView"
             x:DataType="vm:DesignerViewModel"
             Focusable="True"
             KeyDown="OnKeyDown">

    <Grid ColumnDefinitions="200,*,250">

        <!-- Left Panel: Toolbox + Layers -->
        <Grid Grid.Column="0" RowDefinitions="*,200">
            <!-- Toolbox -->
            <Border Grid.Row="0" BorderThickness="0,0,1,0" BorderBrush="#444">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="控件工具箱"
                               Background="#2D2D2D" Foreground="White"
                               Padding="8,4" FontWeight="Bold"/>
                    <ScrollViewer>
                        <StackPanel Spacing="2" Margin="4">
                            <TextBlock Text="基础控件" FontSize="11" Foreground="#888" Margin="0,4,0,2"/>
                            <Button Content="按钮" HorizontalAlignment="Stretch"
                                    Command="{Binding AddControlToCanvasCommand}"
                                    CommandParameter="Button"/>
                            <Button Content="标签" HorizontalAlignment="Stretch"
                                    Command="{Binding AddControlToCanvasCommand}"
                                    CommandParameter="Label"/>
                            <Button Content="输入框" HorizontalAlignment="Stretch"
                                    Command="{Binding AddControlToCanvasCommand}"
                                    CommandParameter="TextBox"/>
                            <Button Content="图片" HorizontalAlignment="Stretch"/>
                            <TextBlock Text="仪表控件" FontSize="11" Foreground="#888" Margin="0,4,0,2"/>
                            <Button Content="仪表盘" HorizontalAlignment="Stretch"
                                    Command="{Binding AddControlToCanvasCommand}"
                                    CommandParameter="Gauge"/>
                            <Button Content="指示灯" HorizontalAlignment="Stretch"
                                    Command="{Binding AddControlToCanvasCommand}"
                                    CommandParameter="IndicatorLight"/>
                            <Button Content="开关" HorizontalAlignment="Stretch"
                                    Command="{Binding AddControlToCanvasCommand}"
                                    CommandParameter="Switch"/>
                            <Button Content="滑动杆" HorizontalAlignment="Stretch"
                                    Command="{Binding AddControlToCanvasCommand}"
                                    CommandParameter="Slider"/>
                            <TextBlock Text="图形" FontSize="11" Foreground="#888" Margin="0,4,0,2"/>
                            <Button Content="直线" HorizontalAlignment="Stretch"
                                    Command="{Binding AddControlToCanvasCommand}"
                                    CommandParameter="Line"/>
                            <Button Content="矩形" HorizontalAlignment="Stretch"
                                    Command="{Binding AddControlToCanvasCommand}"
                                    CommandParameter="Rectangle"/>
                            <Button Content="圆形" HorizontalAlignment="Stretch"
                                    Command="{Binding AddControlToCanvasCommand}"
                                    CommandParameter="Circle"/>
                            <Button Content="椭圆" HorizontalAlignment="Stretch"/>
                            <Button Content="多边形" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Layer Panel -->
            <Border Grid.Row="1" BorderThickness="0,1,1,0" BorderBrush="#444">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Background="#2D2D2D" LastChildFill="True">
                        <Button DockPanel.Dock="Right" Content="+" Width="24" Height="24" Padding="0"
                                ToolTip.Tip="添加图层"
                                Command="{Binding $parent[UserControl].DataContext.AddLayerCommand}"/>
                        <TextBlock Text="图层" Foreground="White" Padding="8,4" FontWeight="Bold" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding CurrentPage.Layers}" x:CompileBindings="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="canvas:HmiLayer">
                                    <Border Padding="2,2">
                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       Padding="4,2" VerticalAlignment="Center"/>
                                            <ToggleButton Grid.Column="1" Width="22" Height="22" Padding="0"
                                                          ToolTip.Tip="显示/隐藏"
                                                          IsChecked="{Binding Visible}"
                                                          Content="👁"/>
                                            <ToggleButton Grid.Column="2" Width="22" Height="22" Padding="0"
                                                          ToolTip.Tip="锁定/解锁"
                                                          IsChecked="{Binding Locked}"
                                                          Content="🔒"/>
                                            <Button Grid.Column="3" Content="×" Width="22" Height="22" Padding="0"
                                                    ToolTip.Tip="删除图层"
                                                    Command="{Binding $parent[UserControl].DataContext.RemoveLayerCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Center: Canvas Area -->
        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*">
            <!-- Page Tabs -->
            <Border Grid.Row="0" Background="#2D2D2D" BorderThickness="0,0,0,1" BorderBrush="#444">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="+ 新建页面"
                            Padding="8,2" Command="{Binding AddPageCommand}"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Pages}" x:CompileBindings="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="2" Margin="4,2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="canvas:HmiPage">
                                    <StackPanel Orientation="Horizontal" Spacing="1">
                                        <Button Content="{Binding Name}" Padding="8,2"
                                                Command="{Binding $parent[UserControl].DataContext.SelectPageCommand}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="×" Padding="4,2" FontSize="10"
                                                ToolTip.Tip="删除页面"
                                                Command="{Binding $parent[UserControl].DataContext.RemovePageCommand}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Alignment / Z-order Toolbar -->
            <Border Grid.Row="1" Background="#252525" BorderThickness="0,0,0,1" BorderBrush="#333">
                <StackPanel Orientation="Horizontal" Margin="4,2" Spacing="2"
                           IsEnabled="{Binding SelectedControl, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock Text="对齐:" VerticalAlignment="Center" Foreground="#888" Margin="0,0,4,0"/>
                    <Button Content="⊢" Padding="4,2" ToolTip.Tip="左对齐" Command="{Binding AlignLeftCommand}"/>
                    <Button Content="⊣" Padding="4,2" ToolTip.Tip="右对齐" Command="{Binding AlignRightCommand}"/>
                    <Button Content="⊤" Padding="4,2" ToolTip.Tip="顶对齐" Command="{Binding AlignTopCommand}"/>
                    <Button Content="⊥" Padding="4,2" ToolTip.Tip="底对齐" Command="{Binding AlignBottomCommand}"/>
                    <Button Content="⊶" Padding="4,2" ToolTip.Tip="水平居中" Command="{Binding AlignCenterVerticalCommand}"/>
                    <Button Content="⊵" Padding="4,2" ToolTip.Tip="垂直居中" Command="{Binding AlignCenterHorizontalCommand}"/>
                    <Separator Width="1" Background="#444" Margin="4,2"/>
                    <Button Content="↔" Padding="4,2" ToolTip.Tip="水平均匀分布" Command="{Binding DistributeHorizontallyCommand}"/>
                    <Button Content="↕" Padding="4,2" ToolTip.Tip="垂直均匀分布" Command="{Binding DistributeVerticallyCommand}"/>
                    <Separator Width="1" Background="#444" Margin="4,2"/>
                    <Button Content="▲▲" Padding="4,2" ToolTip.Tip="置于顶层" Command="{Binding BringToFrontCommand}"/>
                    <Button Content="▲" Padding="4,2" ToolTip.Tip="向上一层" Command="{Binding BringForwardCommand}"/>
                    <Button Content="▼" Padding="4,2" ToolTip.Tip="向下一层" Command="{Binding SendBackwardCommand}"/>
                    <Button Content="▼▼" Padding="4,2" ToolTip.Tip="置于底层" Command="{Binding SendToBackCommand}"/>
                </StackPanel>
            </Border>

            <!-- Canvas with scrolling -->
            <ScrollViewer Grid.Row="2" Background="#1E1E1E"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Border Background="#3C3C3C" Margin="20">
                    <Panel>
                        <Border Name="DesignCanvas"
                                Background="{Binding CurrentPage.BackgroundColor, FallbackValue=White}"
                                Width="{Binding CurrentPage.Width, FallbackValue=1920}"
                                Height="{Binding CurrentPage.Height, FallbackValue=1080}">
                            <!-- Controls rendered from all layers -->
                            <ItemsControl Name="ControlsItemsControl" ItemsSource="{Binding CurrentPage.AllControls}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerTheme>
                                    <ControlTheme TargetType="ContentPresenter"
                                                  x:CompileBindings="False">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                        <Setter Property="Width" Value="{Binding Width}"/>
                                        <Setter Property="Height" Value="{Binding Height}"/>
                                        <Setter Property="Opacity" Value="{Binding Opacity}"/>
                                        <Setter Property="IsVisible" Value="{Binding Visible}"/>
                                    </ControlTheme>
                                </ItemsControl.ItemContainerTheme>
                                <ItemsControl.DataTemplates>
                                    <!-- Button control -->
                                    <DataTemplate x:CompileBindings="False" DataType="core:ButtonControl">
                                        <Panel>
                                            <Button Content="{Binding Text}"
                                                    Background="{Binding BackgroundColor}"
                                                    Foreground="{Binding ForegroundColor}"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"/>
                                            <Border IsHitTestVisible="False" BorderBrush="#00AAFF"
                                                    BorderThickness="2" IsVisible="{Binding IsSelected}"/>
                                        </Panel>
                                    </DataTemplate>
                                    <!-- Label control -->
                                    <DataTemplate x:CompileBindings="False" DataType="core:LabelControl">
                                        <Panel>
                                            <TextBlock Text="{Binding Text}"
                                                       Foreground="{Binding ForegroundColor}"
                                                       FontSize="{Binding FontSize}"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Stretch"
                                                       TextWrapping="Wrap"/>
                                            <Border IsHitTestVisible="False" BorderBrush="#00AAFF"
                                                    BorderThickness="2" IsVisible="{Binding IsSelected}"/>
                                        </Panel>
                                    </DataTemplate>
                                    <!-- TextBox control -->
                                    <DataTemplate x:CompileBindings="False" DataType="core:TextBoxControl">
                                        <Panel>
                                            <TextBox Text="{Binding Text}"
                                                     Watermark="{Binding Placeholder}"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Stretch"/>
                                            <Border IsHitTestVisible="False" BorderBrush="#00AAFF"
                                                    BorderThickness="2" IsVisible="{Binding IsSelected}"/>
                                        </Panel>
                                    </DataTemplate>
                                    <!-- Gauge control -->
                                    <DataTemplate x:CompileBindings="False" DataType="core:GaugeControl">
                                        <Panel>
                                            <Border BorderBrush="#555" BorderThickness="1" CornerRadius="4"
                                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                                                    <TextBlock Text="{Binding Name}" TextAlignment="Center" FontWeight="Bold"/>
                                                    <ProgressBar Value="{Binding Value}"
                                                                 Minimum="{Binding MinValue}"
                                                                 Maximum="{Binding MaxValue}"
                                                                 Width="80" Height="12"/>
                                                    <TextBlock Text="{Binding Value, StringFormat='{}{0:F1}'}"
                                                               TextAlignment="Center" FontSize="10"/>
                                                </StackPanel>
                                            </Border>
                                            <Border IsHitTestVisible="False" BorderBrush="#00AAFF"
                                                    BorderThickness="2" IsVisible="{Binding IsSelected}"/>
                                        </Panel>
                                    </DataTemplate>
                                    <!-- IndicatorLight control -->
                                    <DataTemplate x:CompileBindings="False" DataType="core:IndicatorLightControl">
                                        <Panel>
                                            <Ellipse HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                                     Fill="{Binding OnColor}"
                                                     Stroke="{Binding BorderColor}"
                                                     StrokeThickness="{Binding BorderThickness}"
                                                     ToolTip.Tip="{Binding Name}"/>
                                            <Border IsHitTestVisible="False" BorderBrush="#00AAFF"
                                                    BorderThickness="2" IsVisible="{Binding IsSelected}"/>
                                        </Panel>
                                    </DataTemplate>
                                    <DataTemplate x:CompileBindings="False" DataType="core:SwitchControl">
                                        <Panel>
                                            <ToggleButton IsChecked="{Binding IsOn}"
                                                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                <TextBlock Text="{Binding OnLabel}" HorizontalAlignment="Center"/>
                                            </ToggleButton>
                                            <Border IsHitTestVisible="False" BorderBrush="#00AAFF"
                                                    BorderThickness="2" IsVisible="{Binding IsSelected}"/>
                                        </Panel>
                                    </DataTemplate>
                                    <DataTemplate x:CompileBindings="False" DataType="core:SliderControl">
                                        <Panel>
                                            <StackPanel VerticalAlignment="Center" Spacing="4">
                                                <Slider Value="{Binding Value}"
                                                        Minimum="{Binding Minimum}"
                                                        Maximum="{Binding Maximum}"
                                                        TickFrequency="{Binding TickFrequency}"
                                                        TickPlacement="BottomRight"/>
                                                <TextBlock IsVisible="{Binding ShowValue}"
                                                           Text="{Binding Value, StringFormat='{}{0:F1}'}"
                                                           TextAlignment="Center" FontSize="10"/>
                                            </StackPanel>
                                            <Border IsHitTestVisible="False" BorderBrush="#00AAFF"
                                                    BorderThickness="2" IsVisible="{Binding IsSelected}"/>
                                        </Panel>
                                    </DataTemplate>
                                    <DataTemplate x:CompileBindings="False" DataType="core:RectangleControl">
                                        <Panel>
                                            <Border HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                                    Background="{Binding FillColor}"
                                                    BorderBrush="{Binding StrokeColor}"
                                                    BorderThickness="{Binding StrokeThickness}"
                                                    CornerRadius="{Binding CornerRadius}"/>
                                            <Border IsHitTestVisible="False" BorderBrush="#00AAFF"
                                                    BorderThickness="2" IsVisible="{Binding IsSelected}"/>
                                        </Panel>
                                    </DataTemplate>
                                    <DataTemplate x:CompileBindings="False" DataType="core:CircleControl">
                                        <Panel>
                                            <Ellipse HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                                     Fill="{Binding FillColor}"
                                                     Stroke="{Binding StrokeColor}"
                                                     StrokeThickness="{Binding StrokeThickness}"/>
                                            <Border IsHitTestVisible="False" BorderBrush="#00AAFF"
                                                    BorderThickness="2" IsVisible="{Binding IsSelected}"/>
                                        </Panel>
                                    </DataTemplate>
                                    <DataTemplate x:CompileBindings="False" DataType="core:LineControl">
                                        <Panel>
                                            <Line StartPoint="0,0"
                                                  Stroke="{Binding StrokeColor}"
                                                  StrokeThickness="{Binding StrokeThickness}"
                                                  HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                                            <Border IsHitTestVisible="False" BorderBrush="#00AAFF"
                                                    BorderThickness="2" IsVisible="{Binding IsSelected}"/>
                                        </Panel>
                                    </DataTemplate>
                                    <DataTemplate x:CompileBindings="False" DataType="core:HmiControlBase">
                                        <Panel>
                                            <Border BorderBrush="#888" BorderThickness="1" Background="#2D2D2D">
                                                <TextBlock Text="{Binding Name}" Foreground="White"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                                           FontSize="11"/>
                                            </Border>
                                            <Border IsHitTestVisible="False" BorderBrush="#00AAFF"
                                                    BorderThickness="2" IsVisible="{Binding IsSelected}"/>
                                        </Panel>
                                    </DataTemplate>
                                </ItemsControl.DataTemplates>
                            </ItemsControl>
                        </Border>
                    </Panel>
                </Border>
            </ScrollViewer>
        </Grid>

        <!-- Right Panel: Properties -->
        <Border Grid.Column="2" BorderThickness="1,0,0,0" BorderBrush="#444">
            <DockPanel DataContext="{Binding PropertyPanel}">
                <TextBlock DockPanel.Dock="Top" Text="属性面板"
                           Background="#2D2D2D" Foreground="White"
                           Padding="8,4" FontWeight="Bold"/>
                <TextBox DockPanel.Dock="Top" Watermark="搜索属性..."
                         Text="{Binding SearchText}" Margin="4"/>
                <ScrollViewer>
                    <StackPanel Spacing="4" Margin="4">
                        <TextBlock Text="位置与大小" FontWeight="Bold" FontSize="12" Foreground="#888"/>
                        <Grid ColumnDefinitions="60,*,60,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,2">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="X:" VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Row="0" Grid.Column="1"
                                           Value="{Binding ControlX}" Minimum="-10000" Maximum="10000"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Y:" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            <NumericUpDown Grid.Row="0" Grid.Column="3"
                                           Value="{Binding ControlY}" Minimum="-10000" Maximum="10000"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="宽:" VerticalAlignment="Center" Margin="0,4,0,0"/>
                            <NumericUpDown Grid.Row="1" Grid.Column="1"
                                           Value="{Binding ControlWidth}" Minimum="1" Maximum="10000" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="高:" VerticalAlignment="Center" Margin="4,4,0,0"/>
                            <NumericUpDown Grid.Row="1" Grid.Column="3"
                                           Value="{Binding ControlHeight}" Minimum="1" Maximum="10000" Margin="0,4,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Z层:" VerticalAlignment="Center" Margin="0,4,0,0"/>
                            <NumericUpDown Grid.Row="2" Grid.Column="1"
                                           Value="{Binding ControlZIndex}" Minimum="0" Maximum="9999" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="不透明度:" VerticalAlignment="Center" Margin="4,4,0,0"/>
                            <NumericUpDown Grid.Row="2" Grid.Column="3"
                                           Value="{Binding ControlOpacity}" Minimum="0" Maximum="1"
                                           Increment="0.05" FormatString="0.00" Margin="0,4,0,0"/>
                        </Grid>

                        <TextBlock Text="外观" FontWeight="Bold" FontSize="12" Foreground="#888" Margin="0,8,0,0"/>
                        <Grid ColumnDefinitions="60,*" RowDefinitions="Auto,Auto,Auto" Margin="0,2">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="名称:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ControlName}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="可见:" VerticalAlignment="Center" Margin="0,4,0,0"/>
                            <CheckBox Grid.Row="1" Grid.Column="1"
                                      IsChecked="{Binding ControlVisible}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="锁定:" VerticalAlignment="Center" Margin="0,4,0,0"/>
                            <CheckBox Grid.Row="2" Grid.Column="1"
                                      IsChecked="{Binding ControlLocked}" Margin="0,4,0,0"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>

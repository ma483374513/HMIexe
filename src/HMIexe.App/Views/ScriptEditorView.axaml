<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HMIexe.App.ViewModels"
             xmlns:script="using:HMIexe.Core.Models.Script"
             x:Class="HMIexe.App.Views.ScriptEditorView"
             x:DataType="vm:ScriptEditorViewModel">

    <Grid ColumnDefinitions="220,*">

        <!-- Left: Script list -->
        <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="#444">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Background="#2D2D2D" LastChildFill="False">
                    <TextBlock Text="脚本列表" Foreground="White" Padding="8,6"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="+" Width="28" Height="28" Padding="0"
                            ToolTip.Tip="新建脚本" Command="{Binding AddScriptCommand}" Margin="2"/>
                    <Button DockPanel.Dock="Right" Content="−" Width="28" Height="28" Padding="0"
                            ToolTip.Tip="删除脚本" Command="{Binding RemoveScriptCommand}" Margin="2"/>
                </DockPanel>
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Scripts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="script:HmiScript">
                                <Border Padding="8,6"
                                        Background="Transparent"
                                        PointerPressed="ScriptItem_PointerPressed">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding TriggerType}" FontSize="11" Foreground="#888"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Right: Script editor -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto,120">
            <!-- Script properties bar -->
            <Border Grid.Row="0" Background="#2D2D2D" Padding="8,4">
                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="名称:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Text="{Binding SelectedScript.Name}" Width="120" Margin="0,0,12,0"
                             IsEnabled="{Binding SelectedScript, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    <TextBlock Text="触发类型:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox ItemsSource="{Binding TriggerTypes}" Width="120" Margin="0,0,12,0"
                              SelectedItem="{Binding SelectedScript.TriggerType}"
                              IsEnabled="{Binding SelectedScript, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    <TextBlock Text="间隔(ms):" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <NumericUpDown Value="{Binding SelectedScript.TimerIntervalMs}" Minimum="100" Maximum="3600000"
                                  Width="100" Margin="0,0,12,0"
                                  IsEnabled="{Binding SelectedScript, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    <CheckBox Content="启用" IsChecked="{Binding SelectedScript.IsEnabled}"
                              IsEnabled="{Binding SelectedScript, Converter={x:Static ObjectConverters.IsNotNull}}"
                              VerticalAlignment="Center" Margin="0,0,12,0"/>
                </WrapPanel>
            </Border>

            <!-- Code editor -->
            <TextBox Grid.Row="1"
                     Text="{Binding SelectedScript.Code}"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="NoWrap"
                     FontFamily="Consolas,Courier New,monospace"
                     FontSize="13"
                     Background="#1E1E1E"
                     Foreground="#D4D4D4"
                     CaretBrush="White"
                     BorderThickness="0"
                     IsEnabled="{Binding SelectedScript, Converter={x:Static ObjectConverters.IsNotNull}}"
                     Watermark="选择脚本以开始编辑..."/>

            <!-- Toolbar -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4" Margin="8,4"
                        Background="#252526">
                <Button Content="▶ 编译" Command="{Binding CompileScriptCommand}"
                        IsEnabled="{Binding !IsCompiling}" ToolTip.Tip="编译当前脚本"/>
                <Button Content="▶▶ 运行" Command="{Binding RunScriptCommand}"
                        IsEnabled="{Binding !IsRunning}" ToolTip.Tip="运行当前脚本"/>
                <Separator Width="1" Background="#444" Margin="4,0"/>
                <Button Content="启动定时" Command="{Binding StartTimedScriptsCommand}"
                        ToolTip.Tip="启动所有定时脚本"/>
                <Button Content="停止定时" Command="{Binding StopTimedScriptsCommand}"
                        ToolTip.Tip="停止所有定时脚本"/>
            </StackPanel>

            <!-- Output -->
            <Grid Grid.Row="3" RowDefinitions="Auto,*,Auto,*">
                <TextBlock Grid.Row="0" Text="编译输出" Background="#2D2D2D"
                           Foreground="#888" Padding="8,2" FontSize="11"/>
                <TextBox Grid.Row="1" Text="{Binding CompileOutput}" IsReadOnly="True"
                         FontFamily="Consolas,Courier New,monospace" FontSize="11"
                         Background="#1A1A1A" Foreground="#9CDCFE"
                         TextWrapping="Wrap" AcceptsReturn="True" BorderThickness="0"/>
                <TextBlock Grid.Row="2" Text="运行输出" Background="#2D2D2D"
                           Foreground="#888" Padding="8,2" FontSize="11"/>
                <TextBox Grid.Row="3" Text="{Binding RunOutput}" IsReadOnly="True"
                         FontFamily="Consolas,Courier New,monospace" FontSize="11"
                         Background="#1A1A1A" Foreground="#4EC9B0"
                         TextWrapping="Wrap" AcceptsReturn="True" BorderThickness="0"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
